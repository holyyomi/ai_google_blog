APP_ENV=local
LOG_LEVEL=INFO

# Project paths
DATA_DIR=.
SQLITE_PATH=state/blogspot_automation.db

# Candidate discovery
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
ENABLE_GOOGLE_CUSTOM_SEARCH=false

# News automation
DRY_RUN=true
NEWS_PUBLISH_MODE=dry_run
AUTO_PUBLISH=false
NEWS_MODE=news
AI_BLOG_MODE=true
AI_BLOG_AUTO_PUBLISH=false
NEWS_EXCLUDED_QUERY_GROUPS=
ALLOW_AI_NEWS_TOPICS=true
MIN_TOPIC_SCORE=75
NEWS_MAX_PUBLISH_ATTEMPTS=3

# LLM generation: Gemini first, OpenAI fallback
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Image generation (disabled by default in news automation)
OPENAI_IMAGE_MODEL=gpt-image-1
AI_COVER_IMAGE_URL=
AI_DEFAULT_COVER_IMAGE_URL=https://raw.githubusercontent.com/holyyomi/ai_google_blog/main/assets/ai-blog-cover-default.png

# ImgBB
ENABLE_IMGBB_UPLOAD=false
AI_IMAGE_UPLOAD_KEY=
IMGBB_API_KEY=

# Blogger
BLOGGER_BLOG_ID=
BLOGSPOT_HOME_URL=https://holyyomiai.blogspot.com/
BLOG_BRAND_NAME=holyyomi AI
BLOG_AUTHOR_NAME=holyyomi AI
BLOGGER_ACCESS_TOKEN=
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLOGGER_REFRESH_TOKEN=
BLOGGER_DRY_RUN=true
